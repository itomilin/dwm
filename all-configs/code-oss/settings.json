{
    // ---------------------- USELESS_SHIT ----------------------

    "workbench.settings.showAISearchToggle": false,
    "chat.extensionUnification.enabled": false,
    "chat.tools.todos.showWidget": false,
    "chat.useAgentsMdFile": false,
    "chat.agent.codeBlockProgress": false,
    "chat.agent.enabled": false,
    "chat.agent.thinking.generateTitles": false,
    "chat.allowAnonymousAccess": false,
    "chat.checkpoints.enabled": false,
    "chat.commandCenter.enabled": false,
    "chat.customAgentInSubagent.enabled": false,
    "chat.detectParticipant.enabled": false,
    "chat.disableAIFeatures": true,
    "chat.editing.autoAcceptDelay": false,
    "chat.editing.confirmEditRequestRemoval": false,
    "chat.editing.confirmEditRequestRetry": false,
    "chat.enabled": false,
    "chat.sessions.enabled": false,
    "chat.sessions.viewLocation": "disabled",
    "chat.viewSessions.enabled": false,
    "chat.viewTitle.enabled": false,
    "chat.viewWelcome.enabled": false,
    "editor.experimentalTreeSitterTelemetry": false,
    "editor.inlineSuggest.enabled": false,
    "extensions.ignoreRecommendations": true,
    "github.copilot.chat.enabled": false,
    "github.copilot.editor.enableAutoCompletions": false,
    "github.copilot.enable": false,
    "gitlens.ai.enabled": false,
    "inlineChat.enabled": false,
    "inlineChat.enableV2": false,
    "inlineChat.finishOnType": false,
    "inlineChat.holdToSpeech": false,
    "telemetry.editStats.enabled": false,
    "telemetry.editStats.showDecorations": false,
    "telemetry.editStats.showStatusBar": false,
    "telemetry.enableCrashReporter": false,
    "telemetry.enableTelemetry": false,
    "telemetry.feedback.enabled": false,
    "telemetry.telemetryLevel": "off",
    "workbench.enableExperiments": false,

    // ---------------------- main ----------------------

    "files.watcherExclude": {
        "**/.git/objects/**": true,
        "**/node_modules/**": true,
        "**/dist/**": true,
        "**/build/**": true,
        "**/*.min.js": true,
        "**/*.min.css": true
    },
    "search.exclude": {
        "**/node_modules": true,
        "**/dist": true,
        "**/build": true,
        "**/*.min.js": true,
        "**/.git": true
    },

    "editor.fontFamily": "'Droid Sans Mono', 'monospace', monospace",
    "editor.fontSize": 16,
    "editor.minimap.enabled": false,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "files.trimTrailingWhitespace": true,
    "files.trimTrailingWhitespaceInRegexAndStrings": true,
    "editor.renderWhitespace": "trailing",

    "editor.largeFileOptimizations": true,
    "files.maxMemoryForLargeFilesMB": 512,
    "search.maxResults": 10000,

    "editor.cursorStyle": "line",
    "editor.cursorWidth": 5,
    "editor.cursorBlinking": "blink",
    "editor.cursorSmoothCaretAnimation": "off",

    "editor.lineHeight": 1.35,
    "editor.formatOnSave": true,

    "files.enableTrash": false,
    "editor.inlayHints.enabled": "off",

    "terminal.integrated.gpuAcceleration": "on",
    "workbench.list.smoothScrolling": false,
    "editor.smoothScrolling": false,

    "explorer.autoReveal": false,

    // middle mouse paste OFF
    "editor.selectionClipboard": false,
    "workbench.editorAssociations": {
        "*.png": "imagePreview.previewEditor"
    },

    // ---------------------- terminal ----------------------

    "workbench.panel.defaultLocation": "right",
    "terminal.integrated.location": "panel",
    "terminal.integrated.splitCwd": "workspaceRoot",

    "terminal.integrated.profiles.linux": {
        "bash": {
            "path": "bash",
            "icon": "terminal-bash"
        }
    },

    "terminal.integrated.shellArgs.linux": [],

    "terminal.integrated.scrollback": 10000,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.fontSize": 16,
    "terminal.integrated.lineHeight": 1.35,

    // ---------------------- editor rules ----------------------

    "editor.scrollbar.horizontal": "hidden",
    // "editor.scrollbar.vertical": "hidden",
    "editor.rulers": [
        {
            "column": 80,
            "color": "#ff0000" // Red color for the ruler
        },
        {
            "column": 120,
            "color": "#FFFF00" // Red color for the ruler
        }
    ],

    // ---------------------- editor ----------------------

    "workbench.startupEditor": "none",
    "security.workspace.trust.enabled": false,
    "security.workspace.trust.untrustedFiles": "open",
    "security.workspace.trust.startupPrompt": "never",

    "editor.stickyScroll.enabled": false,
    "editor.renderFinalNewline": "on",
    "workbench.colorCustomizations": {
        "editorWhitespace.foreground": "#00BFFF"
    },

    // ---------------------- clang extension ----------------------

    "editor.defaultFormatter": "llvm-vs-code-extensions.vscode-clangd",
    "C_Cpp.clang_format_path": "/home/tomilin/.vscode-oss/extensions/franneck94.vscode-c-cpp-config-6.3.0-universal/templates/.clang-format",
    "clangd.fallbackFlags": [
      "-std=c++23"
    ],

    // ---------------------- json format ----------------------

    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features",
        "editor.formatOnSave": false
    },

    // ---------------------- tf ----------------------

    "[terraform]": {
      "editor.tabSize": 2,
      "editor.insertSpaces": true,
      "editor.detectIndentation": false
    },

    // ---------------------- go ----------------------

    "[go]": {
        "editor.defaultFormatter": "golang.go", // go extension
        "editor.formatOnSave": true,
        "editor.tabSize": 4,
        "editor.insertSpaces": false,
        "go.formatTool": "goimports",
        "go.lintTool": "golangci-lint", // pacman -S golangci-lint
        "go.lintOnSave": "package"
        // "go.lintFlags": ["--fast"]
    },

    // ---------------------- shell script ----------------------

    "[shellscript]": {
        "editor.detectIndentation": false, // reset default behavior
        "editor.tabSize": 2,
        "editor.insertSpaces": true
    }
}
